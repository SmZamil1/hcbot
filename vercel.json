{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": [
    "BOT_TOKEN",
    "ADMIN_ID",
    "DB_HOST",
    "DB_NAME",
    "DB_USER",
    "DB_PASS",
    "MINI_APP_URL"
  ],
  "rewrites": [
    {
      "source": "/api/webhook",
      "destination": "/api/webhook/route.js"
    }
  ]
}
